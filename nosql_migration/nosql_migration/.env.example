# =============================================================
# Identifiants — Migration PostgreSQL -> Neo4j
# Copiez ce fichier en .env et adaptez les valeurs
# =============================================================

# --- PostgreSQL ---
PG_HOST=postgres
PG_PORT=5432
PG_DB=Crimes
PG_USER=crimes_user
PG_PASSWORD=changeme

# --- Neo4j ---
NEO_URI=bolt://neo4j:7687
NEO_USER=neo4j
NEO_PASSWORD=changeme
NEO_DB=neo4j

# --- Chemins (dans le conteneur) ---
DDL_PATH=./sql_ddl_postgres.sql
CSV_DIR=./csv
